<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/voice_controls_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="false"
    android:focusable="false">

    <!-- ❌ Close -->
    <ImageButton
        android:id="@+id/btn_close_voice"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="25dp"
        android:background="@drawable/bg_red_glow_x"
        android:src="@drawable/ic_close_white"
        android:scaleType="centerInside"
        android:padding="14dp" />

    <!-- 🔁 Refresh -->
    <ImageButton
        android:id="@+id/btn_refresh"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="100dp"
        android:layout_marginStart="25dp"
        android:background="@drawable/bg_blue_glow_refresh"
        android:padding="10dp" />

    <!-- 🛑 Stop -->
    <ImageButton
        android:id="@+id/btn_stop_tts"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="100dp"
        android:layout_marginEnd="25dp"
        android:background="@drawable/bg_red_glow_stop"
        android:src="@android:drawable/ic_media_pause"
        android:tint="#FFFFFF"
        android:scaleType="centerInside"
        android:padding="14dp"
        android:visibility="gone" />
</FrameLayout>
