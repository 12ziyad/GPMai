<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/orb_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 🧵 Blue Thread Line -->
    <View
        android:id="@+id/chat_thread_line"
        android:layout_width="2dp"
        android:layout_height="30dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="0dp"
        android:visibility="gone"
        android:background="@android:color/holo_blue_bright" />

    <!-- 🖼️ Orb Image -->
    <ImageView
        android:id="@+id/orb_image"
        android:layout_width="85dp"
        android:layout_height="85dp"
        android:layout_gravity="center"
        android:src="@drawable/ai_orb"
        android:scaleType="centerInside" />

    <!-- ❤️ Love Mood -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/love_animation"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="top|center_horizontal"
        android:visibility="gone"
        app:lottie_rawRes="@raw/lovemore"
        app:lottie_loop="true"
        app:lottie_autoPlay="true" />

    <!-- 🔥 Fire Burst -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/fire_burst"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:lottie_rawRes="@raw/burningfire"
        app:lottie_autoPlay="false"
        app:lottie_loop="false" />

    <!-- 🔥 Fire Sparks -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/fire_sparks"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:lottie_rawRes="@raw/firesparks"
        app:lottie_loop="true"
        app:lottie_autoPlay="true" />


</FrameLayout>
