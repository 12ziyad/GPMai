<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D9000000"/>
            <corners android:radius="20dp"/>
            <stroke android:width="1dp" android:color="#FFFFFFFF"/>
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1dp" android:color="#00B8FF"/>
            <padding android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp"/>
        </shape>
    </item>
</layer-list>
