<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.gpmai.app">

    <!-- Network / voice -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Camera (for capture) -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Android 13+ media permissions + legacy -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" tools:targetApi="33"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" tools:targetApi="33"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>

    <!-- Overlay + Foreground services -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"
        tools:targetApi="u"/>

    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
        tools:targetApi="u"/>

    <!-- Device control permissions -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>

    <!-- Notifications Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="tiramisu"/>

    <!-- Allow phones with no mic to still install -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false"/>

    <!-- Launch other apps visibility -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN"/>
            <category android:name="android.intent.category.LAUNCHER"/>
        </intent>
        <package android:name="com.whatsapp"/>
        <package android:name="com.instagram.android"/>
        <package android:name="com.google.android.youtube"/>
        <package android:name="com.android.chrome"/>
        <package android:name="com.android.vending"/>
        <package android:name="com.android.settings"/>
    </queries>

    <application
        android:name="${applicationName}"
        android:label="GPMai"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">

        <!-- MAIN ACTIVITY -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Required for image_cropper -->
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"/>

        <!-- Activity used only for MediaProjection consent -->
        <activity
            android:name=".PermissionActivity"
            android:exported="false"
            android:noHistory="true"
            android:finishOnTaskLaunch="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen"/>

        <!-- THE ORB SERVICE -->
        <service
            android:name=".OrbService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone|mediaProjection"/>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>
</manifest>
